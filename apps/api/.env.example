# ────────────────────────────────────────────────────────────────────────────
# Blockora API — Environment Variables
# Copy this file to .env and fill in the required values.
# The application will refuse to start if any required variable is missing
# or invalid. See src/config/env.ts for the full validation schema.
# ────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Example (local): postgresql://postgres:changeme@localhost:5432/blockora_dev
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/blockora_dev

# JWT signing secret — MUST be at least 32 characters (required)
# Generate a strong secret with: openssl rand -base64 48
# ⚠️  Never commit a real secret — rotate immediately if exposed
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Access token lifetime (optional, default: 15m)
# Format: NestJS/jsonwebtoken duration string — e.g. 15m, 1h, 7d
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime (optional, default: 7d)
# Format: NestJS/jsonwebtoken duration string — e.g. 7d, 30d
JWT_REFRESH_EXPIRES_IN=7d

# HTTP server port (optional, default: 3000)
PORT=3000

# Comma-separated list of allowed browser origins for CORS (required)
# Example: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application environment (optional, default: development)
# Allowed values: development | test | production
NODE_ENV=development
